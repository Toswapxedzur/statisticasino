# Path to the SQLite database file. Defaults to ../local_storage/casino.db
# (relative to the statisticasino/ directory). Override if you want the DB
# elsewhere.
DATABASE_PATH=../local_storage/casino.db

# Bootstrap admin: on first login, the account with this exact email is
# auto-promoted to admin. Subsequent admins are promoted via the UI.
ADMIN_EMAIL=zhufengyuejohn@gmail.com
