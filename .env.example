# Aliyun RDS for MySQL (or any MySQL 8 instance).
# Copy this file to `.env` and fill in real values; `.env` is gitignored.
MYSQL_HOST=your-rds-host.mysql.cn-shenzhen.rds.aliyuncs.com
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=statisticasino
# Set to "1" once you enable SSL in the RDS console (Data Security -> SSL).
# Aliyun ships with SSL DISABLED by default; leave at 0 until you flip it.
MYSQL_SSL=0
# Optional connection pool size. 10 is plenty for a school project.
# MYSQL_POOL_LIMIT=10

# ---------------------------------------------------------------------
# Admin: HARDCODED in src/lib/server/auth.js (HARDCODED_ADMIN_*).
# There is no env-driven admin bootstrap any more (the previous
# ADMIN_EMAIL / ADMIN_PASSWORD pair is unused as of schema v7). The
# admin's identity is checked against the hardcoded constants before
# the DB lookup at login. To rotate the admin password, edit
# auth.js and redeploy.
# ---------------------------------------------------------------------

# ---------------------------------------------------------------------
# Gmail SMTP — outbound mail for signup verification codes.
# Leaving GMAIL_USER or GMAIL_APP_PASSWORD blank puts email.js in stub
# mode: codes are logged to stdout (visible via `journalctl -u
# statisticasino`) but not actually emailed, so signup still works
# for testing.
#
# To enable real mail:
#   1. Make sure 2-Step Verification is enabled at
#      https://myaccount.google.com/security on the account you want
#      to send from. App passwords don't exist without 2FA.
#   2. Visit https://myaccount.google.com/apppasswords, type
#      "Statisticasino" as the app name, click Create. Google shows
#      a 16-character password ONCE — copy it. Spaces are decorative.
#   3. Fill in GMAIL_USER (the address) and GMAIL_APP_PASSWORD (the
#      generated string, with or without spaces).
#   4. The From: header is forced to GMAIL_USER (Gmail rewrites
#      mismatched froms). Display name is configurable via
#      GMAIL_FROM_NAME.
#
# Limits: 500 messages/day for personal Gmail, 2000/day for
# Workspace. Verification codes use a tiny fraction of that.
# ---------------------------------------------------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=Statisticasino

# Production only — public origin (scheme + host) so SvelteKit's CSRF
# guard knows what counts as same-site for browser-form POSTs. Not
# needed in dev because Vite serves at http://localhost:5273/.
# ORIGIN=https://stats.example.org
